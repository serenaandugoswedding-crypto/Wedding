{
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ],
  "functions": {
    "api/upload.js":             { "maxDuration": 30 },
    "api/admin/photos/actions.js": { "maxDuration": 60 },
    "api/cron/purge-deleted.js": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path":     "/api/cron/purge-deleted",
      "schedule": "0 4 * * *"
    }
  ]
}
